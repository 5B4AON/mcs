    L --> SIDE
    R --> OPTO

    style USB_SC fill:#1a1e24,stroke:#666,color:#ccc
    style L fill:#2a3a6a,stroke:#6688cc,color:#fff
    style R fill:#2a3a6a,stroke:#6688cc,color:#fff
    style SIDE fill:#2a5a2a,stroke:#66cc66,color:#fff
    style OPTO fill:#5a4a2a,stroke:#ccaa44,color:#fff
    style NOTE fill:#4a3a1a,stroke:#cc8833,color:#ffd
