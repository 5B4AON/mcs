%%{init: {'theme': 'dark', 'themeVariables': { 'fontSize': '14px' }}}%%
graph LR
    subgraph USB_SC["USB Sound Card (Stereo)"]
        direction TB
        L["⬅ Left Channel"]
        R["➡ Right Channel"]
    end

    SIDE["🔊 Sidetone<br/>(speaker)"]
